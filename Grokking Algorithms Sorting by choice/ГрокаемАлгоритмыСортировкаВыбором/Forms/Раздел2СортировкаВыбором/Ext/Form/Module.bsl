&НаКлиенте
Функция СортировкаВыбором_АльтернативныйВариант (Массив)
	
	//В книге приведен хороший пример, но вариант без нового массива мне нравится больше
	Наименьшее = 0;
	// i это начало неотсортированной части массива
	// j это текущий минимум неотсортированной части массива
	Для i = 0 По Массив.ВГраница() Цикл
		Наименьшее = i;
		Для j = i + 1 По Массив.ВГраница() Цикл
			// Ищем минимальный элемент в массиве
			Если Массив[j] < Массив[Наименьшее] Тогда
				Наименьшее = j;
			КонецЕсли;
		КонецЦикла;
		Если Массив[Наименьшее] = Массив[i] Тогда
			// Если минимальный элемент массива равен первому элементу неотсортированной части, то пропускаем
			Продолжить;
		КонецЕсли;
		Смена = Массив[i]; // Производим замену элементов массива
		Массив[i] = Массив[Наименьшее];
		Массив[Наименьшее] = Смена;
	КонецЦикла;
	
	Возврат Массив
	
КонецФункции

