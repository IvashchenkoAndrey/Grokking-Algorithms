Функция Факториал(x)
	
	//Пример вычисления Факториала из книги 
	//def fact(x):
	//
	//if x == 1:                        #Базовый случай
	//	return 1
	//else:
	//	return x * fact(x-1)            #Рекурсивный случай
	
	//Немного про отличия
	//Оператор == в Paython проверяет эквивалентность значений — содержат ли две переменные одинаковые данные.
	//Оператор = в 1C проверяет эквивалентность значений — содержат ли две переменные одинаковые данные.
	
	//Повторяем на 1С
	
	Если x = 1 Тогда                    //Базовый случай
		Возврат 1;
	Иначе
		Возврат x * Факториал(x - 1);   //Рекурсивный случай
	КонецЕсли;
	
