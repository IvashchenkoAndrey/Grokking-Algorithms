&НаКлиенте
Функция СоздатьМассив()
	
	//Создаем массив
	Массив = Новый Массив;
	Массив.Добавить(3);
	Массив.Добавить(5);
	Массив.Добавить(44);
	Массив.Добавить(1);
	Массив.Добавить(15);
	
	Возврат Массив;
	
КонецФункции

&НаКлиенте
Функция БыстраяСортировка(Массив)
	
	//Пример из книги
	//def quick_sort(list_to_sort):
	//
	//if len(list_to_sort) < 2:                   #Базовый случай: массивы длиной 0 или 1 уже отсортированы
	//	return list_to_sort
	//	
	//else:                                       #Рекурсивный случай
	//	
	//	pivot = list_to_sort[0]                   #Опорный элемент — первый элемент массива
	//	
	//	less = [i for i in list_to_sort[1:] if i <= pivot]  #Массивы для элементов меньше/равных опорному
	//		
	//	greater = [i for i in list_to_sort[1:] if i > pivot]#Массив для элементоd больше опорного
	//	
	//	return quick_sort(less) + [pivot] + quick_sort(greater) #Возврат отсортированная левая часть + опорный элемент + отсортированная правая часть
	
	// Базовый случай: массивы длиной 0 или 1 уже отсортированы
	Если Массив.Количество() < 2 Тогда
		Возврат Массив;
	КонецЕсли;
	
	// Опорный элемент — первый элемент массива
	ОпорныйЭлемент = Массив[0];
	
	// Массивы для элементов меньше/равных и больше опорного
	МеньшеИлиРавно = Новый Массив;
	Больше = Новый Массив;
	
	// Разделение массива: пропускаем первый элемент (опорный)
	// В примере 2 цикла, но я добавил 1, в таком виде все работает хорошо
	Для Индекс = 1 По Массив.ВГраница() Цикл
		ЗначениеЭлемента = Массив[Индекс];
		Если ЗначениеЭлемента <= ОпорныйЭлемент Тогда
			МеньшеИлиРавно.Добавить(ЗначениеЭлемента);
		Иначе
			Больше.Добавить(ЗначениеЭлемента);
		КонецЕсли;
	КонецЦикла;
	
	// Рекурсивная сортировка частей и объединение результатов
	ОтсортированнаяЧастьМеньше = БыстраяСортировка(МеньшеИлиРавно);
	ОтсортированнаяЧастьБольше = БыстраяСортировка(Больше);
	
	// Собираем итоговый массив: отсортированная левая часть + опорный элемент + отсортированная правая часть
	Результат = ОтсортированнаяЧастьМеньше;
	Результат.Добавить(ОпорныйЭлемент);
	//Пришлось добавить цикл, так как в массив результат добавляется между чисел элемент с типом массив.
	//Вероятно при изменении рвзделения Результат = ОтсортированнаяЧастьМеньше; прийдется тоже обернуть в цикл
	Для Каждого Элемент Из ОтсортированнаяЧастьБольше Цикл
	Результат.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Результат;
	
	//есть идеи как изменить разделение массивов меньше/равных и больших значений, но вернусь к этому позже
	//в планах ОпорныйЭлемент вывести в поле ввода формы и добавить ветвление для того чтобы значение не выходило за пределы цикла
	
КонецФункции

&НаКлиенте
Процедура СообщитьЗначение(Массив)
	
	//Процедура конторая просто сообщает элементы массива
	Для Каждого Элемент Из Массив Цикл
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = Элемент;
		Сообщение.Сообщить();
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВывестиИсходныйМассив(Команда)
	
	//Команда демонстрации исходного массива до сортировки
	Массив = СоздатьМассив();
	СообщитьЗначение(Массив);
	
