Процедура ВыводСообщения (Результат)
	
	Сообщение = Новый СообщениеПользователю;
	
	//В зависимости от типа значения переменной Результат выводим разные сообщения
	Если ТипЗнч(Результат) = Тип("Число") Тогда
		Сообщение.Текст = "Индекс значения в массиве " + Результат;
	ИначеЕсли ТипЗнч(Результат) = Тип("Строка") Тогда
		Сообщение.Текст = Результат;
	КонецЕсли;
	
	Сообщение.Сообщить();
	
КонецПроцедуры

