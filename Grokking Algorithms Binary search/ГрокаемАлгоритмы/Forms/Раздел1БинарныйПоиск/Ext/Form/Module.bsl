Процедура НайтиЗначениеВМассивеНеЧетныхЧисел(Команда)
	
	//При нажатии на данную кнопку
	//создаем упорядоченный массив четных чисел в цикле
	
	Массив = Новый Массив;
	Для Счетчик = 1 По Объект.КоличествоВМассиве Цикл
		//Ветвление для отделения четных от нечетных чисел с помощью проверки на остаток от деления
		Если НЕ Счетчик % 2 = 0 Тогда
			Массив.Добавить(Счетчик);
		КонецЕсли;
	КонецЦикла;
	
	//Вызов функции бинарного поиска и сразу поместим в переменную результат
	Результат = БинарныйПоиск(Массив, Объект.ИскомоеЗначение);
	
	//Отправляем результат в процедуру вывода сообщения
	ВыводСообщения(Результат);
	
КонецПроцедуры

