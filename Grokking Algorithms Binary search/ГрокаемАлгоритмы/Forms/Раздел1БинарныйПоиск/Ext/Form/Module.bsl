&НаКлиенте
Функция БинарныйПоиск(Массив, ИскомоеЧисло)
	
	//А вот функция ради которой разработана обработка
	//в книге на языке Python функция выглядит так
	//
	//def binary_search(list, item):
	//	low = 0  # В переменных low и high хранятся границы списка где присходит поиск
	//	high = len(list) - 1
	//	
	//	while low <= high:  # Пока область поиска не сократится до одного элемента...
	//		mid = (low + high) // 2  # Если значение (low+high) нечетно, то Python втоматически округлит
										//значение mid в меньшую сторону
	//		guess = list[mid]  # Получаем значение среднего элемента
	//		if guess == item:  # Значение найдено
	//			return mid
	//		elif guess > item:  # Если значение больше искомого
	//			high = mid - 1  # Обновляем верхнюю границу
	//		else:
	//			low = mid + 1  # Если значение меньше искомого
	//	return None  # Если элемент не найден
	
	//Пример использования
	//my_list = [1, 3, 5, 7, 9]
	//print(binary_search(my_list, 3))  # => 1 (индекс 1 соответствует значению 3)
	//print(binary_search(my_list, -1))  # => None
	
	//Итак напишем на языке 1С
	//В переменных Наименьшее и Наибольшее хранятся границы списка где присходит поиск
	Наименьшее = 0; 
	Наибольшее = Массив.Количество()-1;	
	
	//Пока область поиска не сократится до одного элемента...
	Пока Наименьшее <= Наибольшее Цикл
		
		//И тут первое отличие, нужно повторить mid = (low + high) // 2
		//в Python использование оператора "//" гарантирует, что mid будет целым числом,
		//что важно, так как индексы массива должны быть целыми.
		//В 1С будем работать с целыми числами с помощью функции "Цел()".
		// «Цел()» — это инструмент для получения целой части числа путём 
		//отсечения его дробной части. Она не округляет число, а просто удаляет всё, 
		//что находится после запятой.
		//Получаем значение среднего элемента
		Среднее = Цел((Наименьшее + Наибольшее) / 2);
		ПредположительноеЧисло = Массив[Среднее];
		
		//Значение найдено
		Если ПредположительноеЧисло = ИскомоеЧисло Тогда
			Возврат Среднее;
		//Если значение больше искомого обновляем верхнюю границу
		ИначеЕсли ПредположительноеЧисло > ИскомоеЧисло Тогда
			Наибольшее = Среднее - 1;
		//Если значение меньше искомого
		Иначе
			Наименьшее = Среднее + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	//В случае неудачи вернем строку
	Возврат "Искомое значение не найдено в массиве";
	
КонецФункции

